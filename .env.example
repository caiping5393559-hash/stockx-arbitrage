APP_LOGIN_ENABLED=false
APP_USERNAME=admin
APP_PASSWORD=

CLOUD_STORAGE_BACKEND=sqlite
FIREBASE_PROJECT_ID=
FIREBASE_COLLECTION_PREFIX=stockx_goat
FIREBASE_SERVICE_ACCOUNT_B64=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=

STOCKX_HOST=http://43.136.43.128:61030/api/stockx
STOCKX_TOKEN=replace_me
STOCKX_AUTH=replace_me

# both, query, or header
STOCKX_CREDENTIAL_MODE=both

# Adjust these names if the upstream API expects different keys.
STOCKX_TOKEN_PARAM=token
STOCKX_AUTH_PARAM=auth
STOCKX_TOKEN_HEADER=token
STOCKX_AUTH_HEADER=auth

STOCKX_REQUEST_TIMEOUT=20
STOCKX_DB_PATH=data/stockx_arbitrage.sqlite

# Used by the scoring model. 3% payment processing cost: net proceeds = sell price * 0.97.
ESTIMATED_SELLER_FEE_RATE=0.03
BUY_DEPTH_SALES_FRACTION=0.75

# Local background scheduler. When the app is running, it refreshes all imported SKUs every hour.
AUTO_FULL_SYNC_ENABLED=true
AUTO_FULL_SYNC_INTERVAL_MINUTES=60
SYNC_MAX_WORKERS=4
