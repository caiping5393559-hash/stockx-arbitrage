APP_LOGIN_ENABLED=true
APP_USERNAME=admin
APP_PASSWORD=change_this_strong_password

CLOUD_STORAGE_BACKEND=firebase
FIREBASE_PROJECT_ID=replace_me
FIREBASE_COLLECTION_PREFIX=stockx_goat
# Recommended on Render: base64 encode your Firebase service account JSON and put it here.
FIREBASE_SERVICE_ACCOUNT_B64=replace_me
# Alternative local path if you mount a JSON file:
FIREBASE_CREDENTIALS_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=

STOCKX_HOST=http://43.136.43.128:61030/api/stockx
STOCKX_TOKEN=replace_me
STOCKX_AUTH=replace_me
STOCKX_CREDENTIAL_MODE=both
STOCKX_TOKEN_PARAM=token
STOCKX_AUTH_PARAM=auth
STOCKX_TOKEN_HEADER=token
STOCKX_AUTH_HEADER=auth
STOCKX_REQUEST_TIMEOUT=20

# Current app still uses SQLite as local cache on Render disk while Firebase is enabled
# for cloud metadata/events. Full table migration to Firestore is a separate pass.
STOCKX_DB_PATH=/app/data/stockx_arbitrage.sqlite

ESTIMATED_SELLER_FEE_RATE=0.03
BUY_DEPTH_SALES_FRACTION=0.75
AUTO_FULL_SYNC_ENABLED=true
AUTO_FULL_SYNC_INTERVAL_MINUTES=60
SYNC_MAX_WORKERS=4
